THEME=https://raw.githubusercontent.com/seanwcom/Red-Graphite-for-Obsidian/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgShowBacklinks=false
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=true
dgShowTags=true
SITE_NAME_HEADER=魔女摄食中……
SITE_MAIN_LANGUAGE=zh/CHS
SITE_BASE_URL=https://ichii-bal-github-io.vercel.app
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --modal-bg-blur: 3px; --file-line-width: 991px; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless obsidian-app styled-scrollbars theme-light show-inline-title is-floating-nav auto-full-screen show-ribbon show-view-header css-settings-manager composer--SuScheme-light composer--SuScheme-dark composer--SubtleGridCallout composer--DefaultTableStyle composer--ParagraphIndent composer--EnableIndentationGuidLine composer--DefaultOutlineStyle is-focused
USE_FULL_RESOLUTION_IMAGES=false
dgPassFrontmatter=false